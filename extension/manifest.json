{
  "manifest_version": 3,
  "name": "CyberGuard – Nuh Police Fake Ad Detector",
  "version": "1.0.0",
  "description": "AI-powered fake advertisement detection for Indian cyber fraud. Developed for Nuh Police Cyber Crime Unit.",

  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "notifications"
  ],

  "host_permissions": [
    "http://localhost:8000/*",
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "CyberGuard – Click to scan this page"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
